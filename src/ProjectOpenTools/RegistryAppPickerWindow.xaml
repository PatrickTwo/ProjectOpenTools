<Window x:Class="ProjectOpenTools.RegistryAppPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="从系统读取应用"
        Icon="/Assets/AppIcon.ico"
        Width="860"
        Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource StrongTextBrush}"
                               Text="从系统读取应用" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="这里会列出从注册表发现的候选应用，选中后可自动带入名称、路径和图标。" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <ListBox x:Name="RegistryAppsListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding DiscoveredApps}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource CardListBoxItemStyle}">
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="#F9FDFC"
                                                    BorderBrush="#DCEFEB"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#F3FCFA" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                    <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2" />
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EEF9F7" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Border Width="40"
                                            Height="40"
                                            Margin="0,0,12,0"
                                            Background="{StaticResource SurfaceBrush}"
                                            CornerRadius="8"
                                            DockPanel.Dock="Left">
                                        <Image Width="24"
                                               Height="24"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Source="{Binding IconImage}" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource StrongTextBrush}"
                                                   Text="{Binding Name}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{Binding ExePath}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   Text="{Binding ArgumentsTemplate, StringFormat=默认参数：{0}}" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border x:Name="EmptyRegistryAppsBorder"
                            Padding="22"
                            Background="#F9FDFC"
                            BorderBrush="#DCEFEB"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource StrongTextBrush}"
                                       Text="没有发现可导入的应用" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="当前没有从注册表中扫描到可直接使用的应用信息。" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="96"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"
                    Content="取消"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Width="128"
                    Click="ImportButton_Click"
                    Content="导入所选应用"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
