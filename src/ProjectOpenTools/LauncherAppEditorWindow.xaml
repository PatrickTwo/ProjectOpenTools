<Window x:Class="ProjectOpenTools.LauncherAppEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑应用"
        Icon="/Assets/AppIcon.ico"
        Width="640"
        Height="620"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource StrongTextBrush}"
                           Text="应用配置" />
                <TextBlock Grid.Row="2"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="可配置“应用启动”或“终端命令”两种方式。应用启动支持 {projectPath} 占位符，终端命令会在当前项目目录执行。" />

                <TextBlock Grid.Row="4"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource StrongTextBrush}"
                           Text="显示名称" />
                <TextBox x:Name="NameTextBox"
                         Grid.Row="6"
                         Style="{StaticResource EditorTextBoxStyle}" />

                <TextBlock Grid.Row="8"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource StrongTextBrush}"
                           Text="启动方式" />
                <ComboBox x:Name="LaunchModeComboBox"
                          Grid.Row="10"
                          Padding="12,8"
                          SelectionChanged="LaunchModeComboBox_SelectionChanged">
                    <ComboBoxItem Content="应用启动"
                                  Tag="Executable" />
                    <ComboBoxItem Content="终端命令"
                                  Tag="TerminalCommand" />
                </ComboBox>

                <TextBlock x:Name="ExecutablePathLabel"
                           Grid.Row="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource StrongTextBrush}"
                           Text="应用路径" />
                <Grid x:Name="ExecutablePathGrid"
                      Grid.Row="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ExePathTextBox"
                             Style="{StaticResource EditorTextBoxStyle}" />
                    <Button Grid.Column="2"
                            Click="BrowseExePathButton_Click"
                            Content="浏览 exe"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <StackPanel x:Name="ExecutableArgumentsPanel"
                            Grid.Row="15"
                            Margin="0,18,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{StaticResource StrongTextBrush}"
                               Text="参数模板" />
                    <TextBox x:Name="ArgumentsTemplateTextBox"
                             Margin="0,12,0,0"
                             Height="88"
                             VerticalContentAlignment="Top"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Style="{StaticResource EditorTextBoxStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="示例：--folder-uri {projectPath} 或 --reuse-window {projectPath}" />
                </StackPanel>

                <StackPanel x:Name="TerminalCommandPanel"
                            Grid.Row="15"
                            Margin="0,18,0,0"
                            Visibility="Collapsed">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{StaticResource StrongTextBrush}"
                               Text="终端命令" />
                    <TextBox x:Name="CommandTextTextBox"
                             Margin="0,12,0,0"
                             Height="88"
                             VerticalContentAlignment="Top"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Style="{StaticResource EditorTextBoxStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="示例：codex 或 npm run dev。保存后会在项目目录打开 Windows Terminal 并自动执行。" />
                </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="96"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"
                    Content="取消"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Width="110"
                    Click="SaveButton_Click"
                    Content="保存应用"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
