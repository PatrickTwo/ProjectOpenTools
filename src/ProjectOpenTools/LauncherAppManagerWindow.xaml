<Window x:Class="ProjectOpenTools.LauncherAppManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置应用"
        Icon="/Assets/AppIcon.ico"
        Width="860"
        Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource StrongTextBrush}"
                                   Text="应用配置" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="添加或编辑可用于打开项目文件夹的应用。" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Width="90"
                                Margin="0,0,12,0"
                                Click="AddAppButton_Click"
                                Content="新增"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Width="128"
                                Margin="0,0,12,0"
                                Click="ImportFromRegistryButton_Click"
                                Content="从系统读取"
                                Style="{StaticResource ToolbarButtonStyle}" />
                        <Button Width="90"
                                Margin="0,0,12,0"
                                Click="EditAppButton_Click"
                                Content="编辑"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Width="90"
                                Click="DeleteAppButton_Click"
                                Content="删除"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="2">
                    <ListBox x:Name="AppsListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding EditableApps}"
                             ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <DockPanel>
                                        <Border Width="32"
                                                Height="32"
                                                Margin="0,0,12,0"
                                                Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="6"
                                                DockPanel.Dock="Left">
                                            <Image Width="20"
                                                   Height="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Source="{Binding IconImage}" />
                                        </Border>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource StrongTextBrush}"
                                                   Text="{Binding Name}" />
                                    </DockPanel>
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding ExePath}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Text="{Binding SummaryText}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border x:Name="EmptyAppsBorder"
                            Padding="22"
                            Background="#F9FDFC"
                            BorderBrush="#DCEFEB"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource StrongTextBrush}"
                                       Text="暂时还没有应用配置" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="点击右上角“新增”即可录入第一个应用。" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="96"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"
                    Content="取消"
                    Style="{StaticResource SecondaryButtonStyle}" />
            <Button Width="120"
                    Click="ConfirmButton_Click"
                    Content="保存配置"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
