<Application x:Class="ProjectOpenTools.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F4FBF9" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8EEEA" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0D9488" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F97316" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#EA580C" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5B7C78" />
        <SolidColorBrush x:Key="StrongTextBrush" Color="#143A37" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#ECF8F6" />
        <SolidColorBrush x:Key="ButtonLightBrush" Color="#F7FCFB" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#BDDCD7" />
        <SolidColorBrush x:Key="ButtonShadowBrush" Color="#120D9488" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#0B7E74" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Height" Value="48" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ShadowLayer"
                                    Margin="0,4,0,0"
                                    Background="{StaticResource ButtonShadowBrush}"
                                    CornerRadius="6" />
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#0C6A63" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Margin" Value="0,2,0,-2" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource StrongTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonLightBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF8F6" />
                    <Setter Property="BorderBrush" Value="#97CAC2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="148" />
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#FFF7F0" />
            <Setter Property="BorderBrush" Value="#F5C5A2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF0E4" />
                    <Setter Property="BorderBrush" Value="#F0AB77" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="#F9FDFC"
                                BorderBrush="#DCEFEB"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F3FCFA" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF9F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#CBE5E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Application.Resources>
</Application>
